{
    "name": "@php-websocket-rpc/client",
    "version": "0.1.0",
    "description": "TypeScript/JavaScript RPC client for php-websocket-rpc — works in browser and Node.js",
    "license": "MIT",
    "author": "Prasetyo Wicaksono <pras@tuta.io>",
    "keywords": ["rpc", "websocket", "msgpack", "typescript", "async", "browser", "proxy"],
    "homepage": "https://github.com/php-websocket-rpc/typescript-rpc-client",
    "bugs": {
        "url": "https://github.com/php-websocket-rpc/php-websocket-rpc/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/php-websocket-rpc/typescript-rpc-client.git"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "rollup -c rollup.config.js",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@msgpack/msgpack": "^3.1",
        "@rollup/plugin-typescript": "^12.1",
        "rollup": "^4.40",
        "tslib": "^2.8",
        "ws": "^8.20.1"
    },
    "dependencies": {
        "@msgpack/msgpack": "^3.1"
    }
}
